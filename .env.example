# ==========================================
# Research Paper RAG Assistant Configuration
# ==========================================

# LLM Provider Configuration ("groq" or "ollama")
LLM_PROVIDER=groq

# Groq Configuration (Required if LLM_PROVIDER is "groq")
GROQ_API_KEY=gsk_your_api_key_here
# Recommended Groq Models: llama3-8b-8192, gemma2-9b-it, mixtral-8x7b-32768
GROQ_MODEL=llama3-8b-8192

# Ollama Configuration (Required if LLM_PROVIDER is "ollama")
OLLAMA_BASE_URL=http://localhost:11434
# Recommended Ollama Models: llama3, gemma2, phi3
OLLAMA_MODEL=llama3

# Embeddings Configuration
# Options: "all-MiniLM-L6-v2" or "BAAI/bge-large-en-v1.5"
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Storage Directories (Relative to workspace root or absolute)
VECTOR_DB_DIR=data/vector_db
RAW_DATA_DIR=data/raw

# FastAPI Server Settings
HOST=0.0.0.0
PORT=8000

# Streamlit Settings
BACKEND_API_URL=http://localhost:8000
